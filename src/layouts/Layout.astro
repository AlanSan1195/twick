---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article" | "product";
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
  breadcrumb?: Array<{ name: string; item: string }>;
}

const {
  title,
  description = "Simulación de chat para streamers, simula uns audiencia personalizada con el Tema o Viduojuego de tu preferencia y genera comentarios realistas con IA para tu plataforma favorita, Con soporte para con OBS.",
  image = "/desktop-hero-dark.png",
  type = "website",
  noindex = false,
  structuredData: customStructuredData,
  breadcrumb,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://twick.dev",
);
const imageURL = new URL(image, Astro.site || "https://twick.dev");

const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";

const siteName = "Twick";
const siteUrl = "https://twick.dev";
const siteKeywords = "twick, simulacion de audiencia, twick chat, obs chat, OBS chat, simulador de chat, chat simulator, twitch chat simulator, kick chat simulator, practica streaming, stream practice, fake chat generator, streamer tools, OBS overlay, chat de prueba, streaming practice tool, AI chat generator, 7TV emotes, just chatting practice, simulador twitch, simulador kick, entrenamiento streamers";

const baseStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: siteName,
  description: description,
  url: canonicalURL.href,
  applicationCategory: "UtilityApplication",
  operatingSystem: "Web Browser",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
  creator: {
    "@type": "Person",
    name: "Alan San",
    url: siteUrl,
  },
  author: {
    "@type": "Person",
    name: "Alan San",
  },
  publisher: {
    "@type": "Organization",
    name: siteName,
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}/logo-rocket.svg`,
    },
  },
  datePublished: "2024-01-01",
  dateModified: new Date().toISOString().split("T")[0],
  keywords: siteKeywords,
  inLanguage: "es-MX",
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["h1", ".hero-title", "main p"],
  },
  about: {
    "@type": "Thing",
    name: "Streaming Practice Tool",
    description: "Herramienta para simular un chat de streaming",
  },
  audience: {
    "@type": "Audience",
    audienceType: "Streamers, Content Creators",
  },
};

const breadcrumbData = breadcrumb && breadcrumb.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: siteUrl,
    },
    ...breadcrumb.map((item, index) => ({
      "@type": "ListItem",
      position: index + 2,
      name: item.name,
      item: `${siteUrl}${item.item}`,
    })),
  ],
} : {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: siteUrl,
    },
  ],
};

const homepageStructuredData = {
  ...baseStructuredData,
  "@type": "WebApplication",
  mainEntity: {
    "@type": "SoftwareApplication",
    name: siteName,
    description: "Simulador de chat para de streaming, chat personalizado",
    featureList: [
      "Simulación de chat en tiempo real",
      "Comentarios de IA realistas",
      "Soporte para Twitch y Kick",
      "Personalización de viewers",
      "Overlay para OBS",
      "Emotes 7TV",
      "Modo Just Chatting",
    ],
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    reviewCount: "150",
    bestRating: "5",
    worstRating: "1",
  },
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Qué es Twick?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Twick es un simulador de chat que genera comentarios realistas de Twitch y Kick para que puedas practicar streaming antes de tu primer directo.",
      },
    },
    {
      "@type": "Question",
      name: "¿Es gratis?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, Twick es completamente gratis. Puedes usar todas las funciones sin costo.",
      },
    },
    {
      "@type": "Question",
      name: "¿Necesito instalar algo?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No, Twick funciona directamente en tu navegador. Solo necesitas una cuenta para acceder al dashboard.",
      },
    },
    {
      "@type": "Question",
      name: "¿Puedo usar OBS?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, Twick ofrece un overlay que puedes agregar como fuente de navegador en OBS o Streamlabs.",
      },
    },
    {
      "@type": "Question",
      name: "¿Qué juegos soporta?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Twick soporta cualquier juego. Solo escribe el nombre del juego y la IA generará comentarios específicos del contexto.",
      },
    },
    {
      "@type": "Question",
      name: "¿Puedo practicar Just Chatting?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, Twick tiene un modo Just Chatting especial para practicar streams de conversación libre, música, IRL o cualquier tema.",
      },
    },
  ],
};

const howtoStructuredData = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Cómo practicar streaming con Twick",
  description: "Aprende a usar Twick para simular un chat de streaming y practicar antes de tu primer directo.",
  step: [
    {
      "@type": "HowToStep",
      name: "Elige tu juego",
      text: "Escribe el nombre del juego que vas a streamear o selecciona el modo Just Chatting.",
    },
    {
      "@type": "HowToStep",
      name: "Activa el chat",
      text: "Lanza el stream simulado y el chat empieza a fluir con comentarios realistas.",
    },
    {
      "@type": "HowToStep",
      name: "Practica y mejora",
      text: "Ajusta la velocidad del chat y practica responder a diferentes tipos de comentarios.",
    },
  ],
};

const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
  description: description,
  inLanguage: "es-MX",
  potentialAction: {
    "@type": "SearchAction",
    target: `${siteUrl}/?s={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};

const videoStructuredData = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: "Twick - Simulador de Chat para Streaming",
  description: "Practica streaming con comentarios generados por IA para Twitch y Kick",
  thumbnailUrl: `${siteUrl}/desktop-hero-dark.png`,
  uploadDate: "2024-01-01",
  contentUrl: `${siteUrl}/dashboard`,
  embedUrl: `${siteUrl}/dev/chat`,
  duration: "PT0S",
  inLanguage: "es-MX",
};

const finalStructuredData = customStructuredData || (isHomePage ? homepageStructuredData : baseStructuredData);
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Alan San" />
    <meta name="keywords" content={siteKeywords} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:50"} />
    <meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <meta name="language" content="Spanish" />
    <meta name="revisit-after" content="7 days" />
    <meta name="distribution" content="global" />
    <meta name="rating" content="general" />
    <meta name="theme-color" content="#9146FF" />
    <meta name="msapplication-TileColor" content="#9146FF" />
    <meta name="copyright" content="Alan San" />
    <meta name="reply-to" content="contact@twick.dev" />
    <meta name="owner" content="Alan San" />
    <meta name="url" content={canonicalURL.href} />
    <meta name="identifier-URL" content={canonicalURL.href} />
    <meta name="category" content="Technology" />
    <meta name="coverage" content="Worldwide" />
    <meta name="target" content="all" />
    <meta name="HandheldFriendly" content="True" />
    <meta name="MobileOptimized" content="176" />
    <meta name="format-detection" content="telephone=no" />
    
    <!-- RSS/Atom feeds -->
    <link rel="alternate" type="application/rss+xml" title="Twick RSS" href={`${siteUrl}/rss.xml`} />
    <link rel="alternate" type="application/atom+xml" title="Twick Atom" href={`${siteUrl}/atom.xml`} />

    <!-- Geo Tags -->
    <meta name="geo.region" content="MX" />
    <meta name="geo.country" content="Mexico" />
    <meta name="geo.placename" content="Mexico" />

    <!-- Dublin Core Metadata -->
    <meta name="DC.title" content={title} />
    <meta name="DC.description" content={description} />
    <meta name="DC.creator" content="Alan San" />
    <meta name="DC.publisher" content={siteName} />
    <meta name="DC.language" content="es-MX" />
    <meta name="DC.date" content={new Date().toISOString()} />
    <meta name="DC.type" content={type} />
    <meta name="DC.format" content="text/html" />
    <meta name="DC.identifier" content={canonicalURL.href} />

    <!-- Links -->
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="home" href={siteUrl} />
    <link rel="index" href={siteUrl} />

    <!-- Hreflang for international SEO -->
    <link rel="alternate" hreflang="es-MX" href={canonicalURL.href} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL.href} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/logo-rocket.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/logo-rocket.svg" color="#9146FF" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="prefetch" href="/desktop-hero-dark.png" as="image" />
    
    <!-- Security Headers (meta fallback) -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Twick - Practica streaming con audiencia simulada" />
    <meta property="og:image:secure_url" content={imageURL.href} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_MX" />
    {type === "article" && (
      <>
        <meta property="article:author" content="Alan San" />
        <meta property="article:published_time" content="2024-01-01T00:00:00Z" />
        <meta property="article:modified_time" content={new Date().toISOString()} />
        <meta property="article:section" content="Herramientas" />
        <meta property="article:tag" content="streaming" />
        <meta property="article:tag" content="twitch" />
        <meta property="article:tag" content="kick" />
        <meta property="article:tag" content="practice" />
      </>
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL.href} />
    <meta name="twitter:image:alt" content="Twick - Practica streaming con audiencia simulada" />
    <meta name="twitter:image:width" content="1200" />
    <meta name="twitter:image:height" content="630" />
    <meta name="twitter:site" content="@twickdev" />
    <meta name="twitter:creator" content="@alan_san" />
    <meta name="twitter:domain" content="twick.dev" />

    <!-- Generator -->
    <meta name="generator" content={Astro.generator} />

    <!-- Structured Data JSON-LD -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(finalStructuredData)}
    />
    {isHomePage && (
      <>
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(websiteStructuredData)}
        />
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(videoStructuredData)}
        />
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(faqStructuredData)}
        />
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(howtoStructuredData)}
        />
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbData)}
        />
      </>
    )}
    {!isHomePage && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(breadcrumbData)}
      />
    )}

    <!-- Preconnect a servicios externos -->
    <link rel="preconnect" href="https://clerk.twick.dev" />
    <link rel="dns-prefetch" href="https://clerk.twick.dev" />
    <!-- Aplicar color de plataforma antes del primer render para evitar flash -->
    <script is:inline>
      (function () {
        var platforms = {
          twitch: { color: "#9146FF", textColor: "#ffffff", voidColor: "#393073", gridOpacity: "0.35" },
          kick:   { color: "#53FC18", textColor: "#0a1a00", voidColor: "#036617", gridOpacity: "0.18" },
        };
        var stored = localStorage.getItem("preferred-platform");
        var p = platforms[stored] || platforms.twitch;
        document.documentElement.style.setProperty("--color-primary", p.color);
        document.documentElement.style.setProperty("--color-primary-text", p.textColor);
        document.documentElement.style.setProperty("--color-bg-void", p.voidColor);
        document.documentElement.style.setProperty("--grid-opacity", p.gridOpacity);
        document.documentElement.setAttribute("data-platform", stored in platforms ? stored : "twitch");
      })();
    </script>
    <meta name="google-site-verification" content="K2Ny9fKJVr-vRc9D-8sHTB55rgqA0O9_1MdHBZYwGkE" />
  </head>
  <body class="bg-bg-secundary dark:bg-black text-black dark:text-white min-h-screen flex flex-col">

    <!-- Emerald Void — solo dark mode -->
    <div
      class="hidden dark:block fixed inset-0 -z-10 pointer-events-none"
      style="background: radial-gradient(125% 165% at 20% 20%, #000000 60%, var(--color-bg-void) 100%);"
      aria-hidden="true"
    >
    </div>

    <div id="clerk-root" class="locative z-10 flex flex-col flex-1 bg-bg-secundary dark:bg-transparent">
      <slot />
    </div>
    <Footer />
  </body>
</html>
