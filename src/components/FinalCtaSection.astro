---
import { SignedIn, SignedOut, SignInButton } from "@clerk/astro/components";
import EffectoPlus from "./EffectoPlus.astro";
---

<section class=" relative border-t  border-black/25 dark:border-white/20 px-3 md:px-12 py-24 md:py-36" aria-labelledby="cta-heading">

  <div class="grid grid-cols-1 md:grid-cols-[3px_1fr] gap-12 max-w-[900px] md:items-start sm:border sm:dark:border-white/30 py-2 px-[0.8px]  ">
    <div class="hidden md:block w-[3px] min-h-56 bg-primary" aria-hidden="true"></div>
    <div>
      <span class="font-jet text-xs uppercase tracking-[0.25em] text-primary mb-4 block">Listo para empezar</span>
      <h2 id="cta-heading" class="font-departure text-4xl md:text-7xl uppercase text-black dark:text-white leading-none mb-4">
        Tu audiencia<br />te espera.
      </h2>
      <p class="font-jet text-sm sm:text-base text-black/50 dark:text-white/50 max-w-md mb-10 leading-relaxed">
        Crea tu cuenta gratis, elige un juego y lanza tu primer stream de práctica en menos de 30 segundos.
      </p>

      <nav aria-label="CTA final" class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <SignedOut>
          <SignInButton
            mode="modal"
            class="inline-block bg-primary text-primary-text px-10 py-4 text-base cursor-pointer border-none hover:opacity-85 hover:-translate-y-px transition-all duration-150 font-departure uppercase tracking-widest"
          >
            Empezar gratis
          </SignInButton>
          <span class="font-jet text-xs text-black dark:text-white/50">Sin tarjeta de crédito</span>
        </SignedOut>
        <SignedIn>
          <a
            href="/dashboard"
            class="inline-block bg-primary text-primary-text px-10 py-4 text-base cursor-pointer border-none hover:opacity-85 hover:-translate-y-px transition-all duration-150 font-departure uppercase tracking-widest"
            aria-label="Ir al dashboard"
          >
            Abrir Dashboard
          </a>
        </SignedIn>
      </nav>
    </div>
  </div>
  <EffectoPlus />
</section>
