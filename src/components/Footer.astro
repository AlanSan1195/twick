---
import LogoRocket from "../../public/logo-rocket.svg";
import GitPixel from "../../public/assets/gitpixel.svg";

const year = new Date().getFullYear()
---

<footer class="relative z-10 w-full font-departure text-[0.7rem] tracking-[0.08em]" role="contentinfo">
  <!-- Scanline rule — full width -->
  <div
    aria-hidden="true"
    class="h-px mb-5 py-5 max-w-xs sm:max-w-7xl mx-auto scanline-rule"
  ></div>

  <div class="w-full px-6 pb-6">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-y-4 gap-x-6">

      <!-- Brand block -->
      <div class="flex items-center gap-2">
        <a href="/" aria-label="Twick — inicio" class="text-black dark:text-white">
          <LogoRocket class="w-6 h-6" aria-hidden="true" />
        </a>
        <span class="text-black dark:text-white text-sm">Twick</span>
      </div>

      <!-- Navigation links -->
      <nav aria-label="Navegación principal" class="flex items-center gap-4">
        <a href="/" class="text-black dark:text-white hover:text-primary dark:hover:text-primary transition">Inicio</a>
        <a href="/#como-funciona" class="text-black dark:text-white hover:text-primary dark:hover:text-primary transition">Cómo funciona</a>
        <a href="/#caracteristicas" class="text-black dark:text-white hover:text-primary dark:hover:text-primary transition">Características</a>
      </nav>

      <!-- Copyright -->
      <p class="m-0 flex flex-col text-center text-sm lg:text-lg text-pretty text-black dark:text-white uppercase">
        &copy; {year} · todos los derechos reservados · creado por <a href="https://alansan.dev" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary dark:hover:text-primary transition">Alan San</a>
      </p>

      <!-- Social links -->
      <nav aria-label="Redes sociales" class="flex items-center gap-2.5">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="flex items-center justify-center w-8 h-8 rounded-xs text-black dark:text-white"
        >
          <GitPixel class="w-5 h-5" aria-hidden="true" />
        </a>
      </nav>

    </div>
    
    <!-- Structured contact info -->
    <div class="mt-4 pt-4 border-t border-black/20 dark:border-white/20 text-center text-xs text-black/50 dark:text-white/50">
      <p>Contacto: <a href="mailto:contact@twick.dev" class="hover:text-primary dark:hover:text-primary transition">contact@twick.dev</a></p>
    </div>
  </div>
</footer>

<style>
  .scanline-rule {
    background: repeating-linear-gradient(
      to right,
      #201E1D 1px,
      #201E1D 6px,
      transparent 4px,
      transparent 18px
    );
  }
  @media (prefers-color-scheme: dark) {
    .scanline-rule {
      background: repeating-linear-gradient(
        to right,
        rgba(58, 58, 58, 0.922) 0.1px,
        rgba(58, 58, 58, 0.835) 3px,
        transparent 2px,
        transparent 8px
      );
    }
  }
</style>
