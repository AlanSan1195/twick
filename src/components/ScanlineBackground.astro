---
/**
 * ScanlineBackground - Fondo decorativo con líneas horizontales.
 * Uso: Colocarlo dentro de cualquier contenedor con `relative`.
 *       Se adapta al 100% del ancho y alto del padre.
 *
 * Ejemplo:
 *   <section class="relative">
 *     <ScanlineBackground />
 *     <div class="relative z-10">...contenido...</div>
 *   </section>
 */
---

<div class="scanline-rule absolute inset-0 pointer-events-none" aria-hidden="true"></div>
