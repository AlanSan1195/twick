---
import { SignedIn, SignedOut, SignInButton } from "@clerk/astro/components";
import ChatPreview from "./ChatPreview.astro";
import HeaderHero from "./HeaderHero.astro";
---

<section
  class="relative overflow-hidden min-h-screen flex flex-col"
  aria-labelledby="hero-heading"
>
  <!-- Fondo de ruido/textura -->


  <!-- Líneas decorativas horizontales -->
  

  <!-- Header con toggle -->
  <HeaderHero />

  <!-- Contenido principal del hero -->
  <div
    class="relative z-10 flex-1 flex flex-col justify-center px-6 md:px-12 pb-16 pt-4"
  >
    <!-- Eyebrow tag -->
    <div
      class=" flex justify-center sm:inline-flex  items-center gap-2 px-3 py-1 border border-black/40 dark:border-white/20 bg-black/[0.04] dark:bg-white/[0.04] mb-6 sm:self-start"
    >
      <span class="font-jet text-xs sm:text-sm uppercase tracking-[0.2em]"
        >Una audiencia para ti</span
      >
    </div>

    <!-- Título principal -->
    <div class="mb-8">
      <h1
        id="hero-heading"
        class="font-rocket leading-none text-black text-center sm:text-left dark:text-white text-8xl sm:text-[200px]"
      >
        TwicKi
      </h1>
      <div class="relative">

        <!-- estilo Maratone Game -->
        <div
          class="absolute inset-0 bg-[repeating-linear-gradient(-45deg,#000_0_12px,transparent_7px_20px)] sm:bg-[repeating-linear-gradient(-45deg,#000_0_20px,transparent_7px_36px)] dark:bg-[repeating-linear-gradient(-45deg,rgba(255,255,255,0.2)_0_12px,transparent_7px_20px)] sm:dark:bg-[repeating-linear-gradient(-45deg,rgba(255,255,255,0.2)_0_20px,transparent_7px_36px)]"
          aria-hidden="true"
        ></div>

        <div class="relative z-10 inline-block whitespace-nowrap bg-black  px-1 sm:px-4 pr-7 sm:pr-16 [clip-path:polygon(0_0,100%_0,calc(100%-1.5rem)_100%,0_100%)] sm:[clip-path:polygon(0_0,100%_0,calc(100%-3.5rem)_100%,0_100%)] sm:dark:[clip-path:polygon(0_0,100%_0,calc(100%-4.5rem)_100%,0_100%)]">
          <h2
            class="font-departure text-shadow-black text-primary uppercase  text-lg sm:text-7xl m-0 p-0"
          >
            Chat Simulator
          </h2>
        </div>
      </div>
    </div>

    <!-- Descripción y CTA en grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-[1.4fr_1fr] gap-8 max-w-[1100px] md:items-start"
    >
      <ChatPreview />
      <!-- CTA -->
      <div class="flex flex-col gap-6">
        <nav aria-label="Acciones principales" class="flex flex-col gap-4">
          <SignedOut>
            <SignInButton
              mode="modal"
              class="inline-block bg-primary text-primary-text px-8 py-3.5 text-[0.9rem] cursor-pointer border-none text-center hover:opacity-85 hover:-translate-y-px active:translate-y-0 transition-all duration-150 font-departure uppercase tracking-widest"
            >
              Comenzar Stream
            </SignInButton>
            <p
              class="font-jet text-sm text-black/50 dark:text-white/40 text-center"
            >
              Gratis · Sin tarjeta · Sin excusas
            </p>
          </SignedOut>
          <SignedIn>
            <a
              href="/dashboard"
              class="inline-block bg-primary text-primary-text px-8 py-3.5 text-[0.9rem] cursor-pointer border-none text-center hover:opacity-85 hover:-translate-y-px active:translate-y-0 transition-all duration-150 font-departure uppercase tracking-widest"
              aria-label="Ir al panel de control del simulador"
            >
              Ir al Dashboard
            </a>
          </SignedIn>
        </nav>

        <!-- Stats rápidos -->
        <div
          class=" flex items-center gap-4 py-4 border-t border-black dark:border-white/40"
        >
          <div class="flex flex-col gap-0.5">
            <span class="text-sm sm:text-3xl font-departure text-primary"
              >7TV</span
            >
            <span
              class="font-jet text-xs text-black/50 dark:text-white/50 leading-none"
              >Emotes reales</span
            >
          </div>
          <div class="w-px h-8  bg-black dark:bg-white/40" aria-hidden="true">
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-sm sm:text-3xl font-departure text-primary"
              >IA</span
            >
            <span
              class="font-jet text-xs text-black/50 dark:text-white/50 leading-none"
              >Mensajes únicos</span
            >
          </div>
          <div class="w-px h-8  bg-black dark:bg-white/40" aria-hidden="true">
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-sm sm:text-3xl font-departure text-primary"
              >2x</span
            >
            <span
              class="font-jet text-xs text-black/50 dark:text-white/50 leading-none"
              >Plataformas</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div
    class="hidden absolute bottom-0 right-10 sm:flex flex-col items-center gap-2"
    aria-hidden="true"
  >
    <span
      class="font-jet text-sm uppercase tracking-[0.25em] text-black dark:text-white"
      >scroll</span
    >
    <div class="scroll-line w-[2.3px] h-12"></div>
  </div>
</section>

<style>
  /* Noise overlay - SVG texture background (not expressible in Tailwind) */



  /* Pulse dot animation */
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.85);
    }
  }
  .animate-pulse-dot {
    animation: pulse-dot 2.5s ease-in-out infinite;
  }

  /* Chat row hover */
  .chat-row:hover .chat-msg {
    background: rgba(255, 255, 255, 0.05);
  }

  /* Scroll line animation */
  .scroll-line {
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3), transparent);
    animation: scroll-drop 2s ease-in-out infinite;
  }
  @media (prefers-color-scheme: dark) {
    .scroll-line {
      background: linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.5),
        transparent
      );
    }
  }
  @keyframes scroll-drop {
    0% {
      transform: scaleY(0);
      transform-origin: top;
    }
    50% {
      transform: scaleY(1);
      transform-origin: top;
    }
    51% {
      transform: scaleY(1);
      transform-origin: bottom;
    }
    100% {
      transform: scaleY(0);
      transform-origin: bottom;
    }
  }

</style>
