---
---

<section class="relative border-t border-black/25 dark:border-white/20 px-6 md:px-12 py-24 md:py-36 scanlines-bg overflow-hidden" aria-labelledby="features-heading">

  <!-- Checker accent — esquina superior derecha -->
  <div class="checker-pattern absolute top-0 right-0 w-28 h-5 opacity-30 dark:opacity-20 pointer-events-none" aria-hidden="true"></div>

  <!-- Section label -->
  <div class="flex items-center gap-6 mb-12">
    <span class="font-jet text-xs flex items-center gap-x-7 sm:gap-x-10 uppercase tracking-[0.25em] text-black dark:text-white/50">
      <!-- + -->
      <div class="relative">
        <div class="absolute w-px h-6 bg-black dark:bg-white/50"></div>
        <div class="w-px h-6 bg-black dark:bg-white/50 rotate-90"></div>
      </div>
      <span class="text-black dark:text-white/50">Características</span>
    </span>
    <div class="flex-1 h-px max-w-6 sm:max-w-48 bg-black dark:bg-white/50" aria-hidden="true"></div>
    <!-- Metadata label derecha -->
    <span class="meta-label hidden sm:block ml-auto">FEATURE_SET · v2.0</span>
  </div>

  <h2 id="features-heading" class="font-departure text-3xl md:text-5xl uppercase text-black dark:text-white mb-16 max-w-3xl leading-tight">
    Todo lo que necesitas<br /><span class="text-primary">para practicar</span>
  </h2>

  <!-- Grid de características — estilo blueprint con bordes finos -->
  <div class="features-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr] lg:grid-rows-[auto_auto] gap-px bg-black/20 dark:bg-white/20">

    <!-- Card 1: IA (row-span-2) -->
    <article class="relative bg-bg-secundary flex flex-col justify-center text-pretty dark:bg-black p-8 lg:row-span-2">
      <!-- Corner mark superior izquierdo -->
      <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <!-- Corner mark inferior derecho -->
      <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <!-- Metadata en esquina superior derecha -->
      <span class="absolute top-3 right-3 meta-label hidden sm:block">01 / IA</span>

      <div class="mb-4 leading-none" aria-hidden="true">
        <span class="font-geistGrid text-4xl text-primary">◼</span>
      </div>
      <h3 class="font-departure text-xl uppercase text-black dark:text-white mb-2">Chat con IA generativa</h3>
      <p class="font-jet text-xs sm:text-base text-black/60 dark:text-white/60 leading-relaxed">
        Genera mensajes contextualmente relevantes para tu juego o tema. No son frases genéricas: son comentarios que realmente dirían espectadores reales.
      </p>
    </article>

    <!-- Card 2: 7TV -->
    <article class="relative bg-bg-secundary dark:bg-black p-8">
      <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <span class="absolute top-3 right-3 meta-label hidden sm:block">02 / 7TV</span>

      <div class="mb-4 leading-none" aria-hidden="true">
        <span class="font-geistCircle text-3xl text-primary">●</span>
      </div>
      <h3 class="font-departure text-base uppercase text-black dark:text-white mb-2">Emotes 7TV globales</h3>
      <p class="font-jet text-xs sm:text-base text-black/60 dark:text-white/60 leading-relaxed">
        Integración con 7tv para dar mas realismo al chat, sin necesidad de configurar nada.
      </p>
    </article>

    <!-- Card 3: Velocidad -->
    <article class="relative bg-bg-secundary dark:bg-black p-8">
      <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <span class="absolute top-3 right-3 meta-label hidden sm:block">03 / SPD</span>

      <div class="mb-4 leading-none" aria-hidden="true">
        <span class="font-geistLine text-3xl text-primary">▬</span>
      </div>
      <h3 class="font-departure text-base uppercase text-black dark:text-white mb-2">Velocidad ajustable</h3>
      <p class="font-jet text-xs sm:text-base text-black/60 dark:text-white/60 leading-relaxed">
        Desde chat tranquilo hasta hype máximo. Cuatro presets de velocidad para simular cualquier tamaño de audiencia.
      </p>
    </article>

    <!-- Card 4: Plataformas -->
    <article class="relative bg-bg-secundary dark:bg-black p-8">
      <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <span class="absolute top-3 right-3 meta-label hidden sm:block">04 / PLT</span>

      <div class="flex gap-2 mb-4" aria-label="Plataformas compatibles">
        <span class="px-3 py-1 text-xs tracking-[0.1em] uppercase bg-[#9146FF] text-white font-departure">Twitch</span>
        <span class="px-3 py-1 text-xs tracking-[0.1em] uppercase bg-[#53FC18] text-[#0a1a00] font-departure">Kick</span>
      </div>
      <h3 class="font-departure text-base uppercase text-black dark:text-white mb-2 mt-0">Twitch &amp; Kick</h3>
      <p class="font-jet text-xs sm:text-base text-black/60 dark:text-white/60 leading-relaxed">
        Cambia de plataforma con un click. El tema visual completo se adapta al estilo de cada una.
      </p>
    </article>

    <!-- Card 5: Just Chatting (col-span-2) -->
    <article class="relative bg-bg-secundary dark:bg-black p-8 lg:col-span-2">
      <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-black/25 dark:border-white/20" aria-hidden="true"></div>
      <span class="absolute top-3 right-3 meta-label hidden sm:block">05 / JC</span>
      <!-- Checker accent en la card más ancha -->
      <div class="checker-pattern-primary absolute bottom-0 right-0 w-16 h-4 opacity-40 pointer-events-none" aria-hidden="true"></div>

      <div class="mb-4 leading-none" aria-hidden="true">
        <span class="font-geistSquare text-3xl text-primary">■</span>
      </div>
      <h3 class="font-departure text-base uppercase text-black dark:text-white mb-2">Just Chatting mode</h3>
      <p class="font-jet text-xs sm:text-base text-black/60 dark:text-white/60 leading-relaxed">
        No solo para gaming. Practica charlas de vida, música, IRL o cualquier tema libre. La IA adapta el tono del chat automáticamente.
      </p>
    </article>

  </div>

</section>
