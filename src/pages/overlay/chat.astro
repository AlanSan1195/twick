---
/**
 * Overlay de chat para OBS Browser Source.
 * Página minimal sin Layout, Header ni Footer.
 * Fondo transparente para chroma/transparencia nativa de OBS.
 *
 * Query params esperados:
 *   token    - Token de autenticación del overlay (requerido)
 *   game     - Nombre del juego o tema (requerido)
 *   mode     - 'game' | 'justchatting' (default: 'game')
 *   speed    - Índice del preset de velocidad 0-3 (default: 2)
 *   platform - 'twitch' | 'kick' (default: 'twitch')
 */
import ChatOverlay from '../../components/ChatOverlay';
import '../../styles/global.css';

const url = new URL(Astro.request.url);
const token = url.searchParams.get('token') ?? '';
const game = url.searchParams.get('game') ?? '';
const mode = (url.searchParams.get('mode') ?? 'game') as 'game' | 'justchatting';
const speed = Number(url.searchParams.get('speed') ?? '2');
const platform = (url.searchParams.get('platform') ?? 'twitch') as 'twitch' | 'kick';
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Twick Overlay</title>

    {/* Aplicar CSS custom properties de plataforma antes del primer render */}
    <script is:inline define:vars={{ platform }}>
      const vars = platform === 'kick'
        ? { '--color-primary': '#53FC18', '--color-primary-text': '#0a1a00', '--color-bg-void': '#036617', '--grid-opacity': '0.10' }
        : { '--color-primary': '#9146FF', '--color-primary-text': '#ffffff', '--color-bg-void': '#393073', '--grid-opacity': '0.16' };

      const root = document.documentElement;
      for (const [k, v] of Object.entries(vars)) {
        root.style.setProperty(k, v);
      }
      root.setAttribute('data-platform', platform);
    </script>

    <style is:global>
      /* Fondo totalmente transparente para OBS */
      html, body {
        background: transparent !important;
        margin: 0;
        padding: 0;
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <ChatOverlay
      client:only="react"
      token={token}
      game={game}
      mode={mode}
      speed={speed}
      platform={platform}
    />
  </body>
</html>
